---
import BaseLayout from '../../layouts/BaseLayout.astro'
import MotoCard from '../../components/MotoCard.astro'
import AdSlot from '../../components/AdSlot.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const motos = await getCollection('motos')
  const marcas = [...new Set(motos.map(m => m.data.marca.toLowerCase()))]
  return marcas.map(marca => ({
    params: { marca },
    props: {
      marcaCapitalized: marca.charAt(0).toUpperCase() + marca.slice(1),
      motos: motos.filter(m => m.data.marca.toLowerCase() === marca).map(m => m.data),
    },
  }))
}

const { marcaCapitalized, motos } = Astro.props

const MARCAS_INFO: Record<string, string> = {
  AKT: 'AKT Motos es la marca colombiana más importante del sector, con una red de concesionarios que cubre prácticamente todos los municipios del país. Su portafolio está pensado para el mercado local: motos económicas, resistentes y con repuestos disponibles en cualquier taller. La NKD 125, la TTR 125 doble propósito y la Flex Evolution semiautomática son algunos de sus modelos más vendidos. AKT compite directamente con Bajaj y Hero en el segmento de entrada, pero su ventaja diferencial es la capilaridad: encuentras servicio técnico y repuestos originales hasta en pueblos donde otras marcas no llegan. También han incursionado en cilindradas mayores con modelos adventure y naked, aunque su fortaleza sigue estando en las motos de 125 a 200 cc. Para el comprador colombiano que prioriza el costo de mantenimiento y la disponibilidad de repuestos sobre las prestaciones, AKT es casi siempre la opción más práctica.',
  Suzuki: 'Suzuki tiene una presencia sólida en Colombia gracias a modelos que han marcado generaciones de motociclistas. La GN 125 es un ícono de confiabilidad que se ha mantenido vigente por décadas, y la Gixxer SF 250 representa la entrada al segmento deportivo con carenado completo. En el portafolio local también destacan la GSX-S150 ABS, una 150 cc con refrigeración líquida y DOHC que no tiene competencia directa en prestaciones. La red de servicio Suzuki en Colombia es amplia, con concesionarios en las principales ciudades y cobertura en ciudades intermedias. El respaldo de la marca japonesa y la calidad de ensamble hacen que las Suzuki mantengan un buen valor de reventa. Para el motero que busca algo distinto a las marcas masivas sin sacrificar confiabilidad japonesa, Suzuki ofrece un balance atractivo entre calidad y precio.',
  TVS: 'TVS Motor Company es un fabricante indio con una presencia creciente en Colombia gracias a modelos que destacan por su relación precio-equipamiento. La Apache RTR 200 4V es una de las naked más completas del segmento, con tres modos de manejo seleccionables, ABS de doble canal y refrigeración por aceite. La Apache RTR 160 compite directamente con la Yamaha FZ 3.0 y la Hero Xtreme 160R, ofreciendo doble freno de disco y un motor que responde bien en ciudad. En el segmento de 125 cc, la Raider se destaca por tener inyección electrónica y doble freno de disco cuando la mayoría de sus rivales todavía usan carburador y tambor trasero. El principal desafío de TVS en Colombia sigue siendo la red de servicio, que aunque ha mejorado en los últimos años, todavía no tiene la cobertura de Honda o AKT en pueblos pequeños. Para el comprador urbano que valora la tecnología y el rendimiento por encima de la tradición de marca, TVS es una opción cada vez más difícil de ignorar.',
  Bajaj: 'Bajaj Auto es el fabricante indio más grande del mundo y en Colombia compite directamente con AKT en el segmento de motos económicas. La Pulsar NS125 y la CT125 son sus modelos de entrada, ofreciendo diseño deportivo a precios agresivos. En el segmento de las 200 cc, la Pulsar NS200 FI ABS SC es una de las naked más vendidas del país, con 24 HP y un precio competitivo de $13.199.000 que la coloca como la opción sensata frente a la KTM 200 Duke. Bajaj ha mejorado significativamente su red de servicio en los últimos años, con concesionarios en la mayoría de las capitales departamentales y repuestos disponibles en el mercado de posventa. La tecnología DTS-i de triple bujía y el monoamortiguador Nitrox son sellos distintivos de la marca. Para el motero joven que busca una naked con estilo deportivo sin gastar lo que cuesta una KTM o una Honda, Bajaj sigue siendo la referencia en relación costo-beneficio.',
  Yamaha: 'Yamaha Motor es sinónimo de tecnología y rendimiento en el mercado colombiano. Su portafolio abarca desde la YBR 125, una de las motos de trabajo más confiables del país, hasta la MT-15 con motor VVA de distribución variable que entrega 18.6 HP, la cifra más alta del segmento de 155 cc. La NMAX 155 es el scooter más vendido de Colombia, con ABS de doble canal y un motor Blue Core eficiente. La FZ Versión 3.0 FI representa la naked equilibrada por excelencia, con 13 HP y el tanque más grande de su categoría (13 litros). La red de concesionarios Yamaha es una de las más extensas del país, con presencia en la mayoría de los municipios colombianos y un servicio postventa que respalda la inversión. El valor de reventa de las Yamaha se mantiene alto porque la percepción de calidad y durabilidad está muy arraigada entre los compradores colombianos. Para quien busca una moto que dure años con mantenimiento básico, Yamaha es casi siempre la respuesta correcta.',
  Honda: 'Honda es el fabricante de motos más grande del mundo y en Colombia su presencia es igual de dominante. La CB125F con inyección PGM-FI es la entrada al universo Honda, ofreciendo un motor que arranca siempre sin importar el clima. La CB190R 2.0 ocupa un nicho único de 184 cc con suspensión invertida y ABS delantero. En el segmento doble propósito, la XR150L 2.0 ABS es la evolución de un modelo con más de 20 años en el mercado colombiano, con ABS delantero y suspensión invertida. La red de servicio Honda, operada por Fanalca, es la más grande del país: encuentras concesionarios y talleres autorizados en cada ciudad y en la mayoría de los municipios. Los repuestos originales se consiguen en cualquier almacén de repuestos, no solo en concesionarios. Esa capilaridad es la razón principal por la que Honda mantiene su posición de liderazgo, a pesar de que en algunos segmentos sus modelos tienen especificaciones más conservadoras que la competencia. Para el comprador que prioriza la tranquilidad de tener servicio técnico cerca y repuestos disponibles, Honda no tiene rival.',
  Hero: 'Hero MotoCorp es el fabricante más grande de India y desde su llegada a Colombia ha buscado posicionarse con modelos que ofrecen una buena relación precio-equipamiento. La Hunk 125R y la Xtreme 160R son sus representantes en el mercado local. La Xtreme 160R compite directamente con la Yamaha FZ 3.0 y la TVS Apache RTR 160, ofreciendo 15.2 HP con inyección electrónica a un precio de $5.490.000 que la hace muy competitiva. El principal desafío de Hero sigue siendo la red de servicio: aunque la marca ofrece garantía de 2 años, la cobertura de concesionarios es limitada en comparación con Honda, Yamaha o AKT, concentrándose principalmente en las grandes ciudades. Para el comprador que vive en Bogotá, Medellín, Cali o Barranquilla y quiere un modelo con buen equipamiento por menos de $6 millones, Hero es una opción a considerar seriamente. Para quienes están en zonas rurales o ciudades intermedias, conviene verificar primero si hay un taller autorizado cerca antes de decidir la compra.',
  KTM: 'KTM es el fabricante austriaco especializado en motos de alto rendimiento, conocido por su característico color naranja y su filosofía de peso ligero y chasis deportivo. En Colombia, la KTM 200 Duke es la puerta de entrada a la marca, ofreciendo 24.7 HP, horquilla invertida WP APEX de 45 mm y ABS ByBre de doble canal, componentes que no se encuentran en ninguna rival al mismo precio. Desde 2026, KTM extendió la garantía a 4 años sin límite de kilometraje, un movimiento que busca tranquilizar al comprador colombiano frente al costo de mantenimiento de una marca importada. La red de concesionarios KTM está presente en las principales ciudades del país, aunque la cobertura no es tan amplia como la de marcas japonesas. Los repuestos originales tienen un costo mayor que los de una Bajaj o una AKT, y no siempre están disponibles de inmediato. Para el motero que valora la experiencia de manejo por encima del costo de mantenimiento, y que busca componentes de suspensión y frenado de nivel superior, KTM ofrece una propuesta única en el segmento de las 200 cc.',
  'Royal Enfield': 'Royal Enfield es una marca británica con más de 120 años de historia, y desde 2023 cuenta con una planta de ensamble en Antioquia que refuerza su presencia en Colombia. La Classic 350 es su modelo insignia: un motor de 349 cc con 27 Nm de torque, inyección electrónica, ABS de doble canal y un diseño clásico con llantas de rayos y faro redondo. El ensamble local permite que la Classic 350 tenga componentes nacionales en pintura y detalles, conectándola con el mercado colombiano de una forma que ninguna otra moto importada logra. El precio de $19.900.000 la coloca en un segmento aspiracional, compitiendo más con motos de mayor cilindraje que con las naked y deportivas de su mismo rango de precio. La red de servicio Royal Enfield ha crecido significativamente desde el inicio del ensamble local, con concesionarios en las principales ciudades. Para el motero que busca una experiencia de manejo pausada y con carácter, donde el estilo y la presencia pesan tanto como las prestaciones, la Royal Enfield Classic 350 es una decisión que va más allá de lo racional y se acerca más a una declaración de principios.',
}

const marcaInfo = MARCAS_INFO[marcaCapitalized] || `${marcaCapitalized} es una marca de motos disponible en Colombia con modelos para todos los segmentos y necesidades.`
const precios = motos.map(m => m.precio_cop)
const minPrecio = Math.min(...precios)
const maxPrecio = Math.max(...precios)

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Motos ${marcaCapitalized} en Colombia`,
  description: `Catálogo de motos ${marcaCapitalized} disponibles en Colombia. Precios desde $${minPrecio.toLocaleString('es-CO')} hasta $${maxPrecio.toLocaleString('es-CO')}.`,
}
---

<BaseLayout
  title={`Motos ${marcaCapitalized} en Colombia - Fichas Técnicas y Precios`}
  description={`Encuentra todas las motos ${marcaCapitalized} disponibles en Colombia. ${motos.length} modelos con fichas técnicas, precios actualizados, especificaciones y comparativas.`}
  canonical={`/marcas/${marcaCapitalized.toLowerCase()}`}
  schema={schema}
  breadcrumbs={[
    { name: 'Inicio', path: '/' },
    { name: 'Fichas Técnicas', path: '/fichas-tecnicas' },
    { name: marcaCapitalized, path: `/marcas/${marcaCapitalized.toLowerCase()}` },
  ]}
>
  <div class="page-wrapper">
    <div class="container">
      <nav class="breadcrumbs">
        <a href="/">Inicio</a>
        <span>/</span>
        <a href="/fichas-tecnicas">Fichas Técnicas</a>
        <span>/</span>
        <span>{marcaCapitalized}</span>
      </nav>
      <div class="marca-header">
        <h1>Motos {marcaCapitalized}</h1>
        <p class="marca-desc">{marcaInfo}</p>
        <div class="marca-stats">
          <span>{motos.length} modelos</span>
          <span>Desde {new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0 }).format(minPrecio)}</span>
        </div>
      </div>
      <div class="grid-3">
        {motos.map(moto => <MotoCard moto={moto} />)}
      </div>
      <div style="margin-top: 24px; text-align: center">
        <AdSlot id="marca-bottom" />
      </div>
    </div>
  </div>
</BaseLayout>
