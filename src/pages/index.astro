---
import BaseLayout from '../layouts/BaseLayout.astro'
import MotoCard from '../components/MotoCard.astro'
import BlogCard from '../components/BlogCard.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3)
  .map(p => ({ ...p.data, slug: p.slug }))

const motos = await getCollection('motos')
const motosDataMap = motos.map(m => m.data)

const idsDestacadas = ['akt-nkd-125', 'yamaha-nmax-155', 'hero-hunk-160r', 'akt-ttr-125', 'tvs-apache-rtr-160', 'yamaha-mt-15']
const destacadas = idsDestacadas
  .map(id => motosDataMap.find(m => m.id === id))
  .filter(Boolean)

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'NetMotos',
  url: 'https://netmotos.lat',
  description: 'Fichas técnicas de motos en Colombia de todos los segmentos y cilindrajes. Compara modelos, calcula consumo y descubre la moto ideal.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://netmotos.lat/fichas-tecnicas?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
}
---

<BaseLayout title="Inicio" canonical="/" schema={schema} breadcrumbs={[{ name: 'Inicio', path: '/' }]}>
  <section class="hero">
    <div class="container hero-content">
      <h1>La guía definitiva de motos en Colombia</h1>
      <p>Fichas técnicas de todos los segmentos y cilindrajes, comparador interactivo y calculadora de consumo para motos en Colombia.</p>
      <div class="hero-actions">
        <a href="/fichas-tecnicas" class="btn btn-primary">Ver Fichas Técnicas</a>
        <a href="/comparador" class="btn btn-outline">Comparar Motos</a>
      </div>
    </div>
  </section>

  <div class="ticker-bar">
    <div class="ticker-track" id="tickerTrack">
      <span class="ticker-item">23+ fichas técnicas actualizadas</span>
      <span class="ticker-sep">•</span>
      <span class="ticker-item">Compara modelos lado a lado</span>
      <span class="ticker-sep">•</span>
      <span class="ticker-item">Calcula tu consumo de gasolina</span>
      <span class="ticker-sep">•</span>
      <span class="ticker-item">Guías para elegir tu primera moto</span>
      <span class="ticker-sep">•</span>
    </div>
  </div>

  <section class="container section">
    <div class="section-title">
      <h2>Últimas Noticias</h2>
    </div>
    <div class="grid-3">
      {posts.map(post => <BlogCard post={post} />)}
    </div>
    <div style="text-align: center; margin-top: 24px">
      <a href="/blog" class="btn btn-secondary">Ver Todas las Noticias</a>
    </div>
  </section>

  <section class="container section">
    <div class="section-title">
      <h2>Motos Destacadas</h2>
    </div>
    <div class="grid-3">
      {destacadas.map(moto => <MotoCard moto={moto} />)}
    </div>
    <div style="text-align: center; margin-top: 24px">
      <a href="/fichas-tecnicas" class="btn btn-secondary">Ver Todas las Motos</a>
    </div>
  </section>

  <section class="container section">
    <div class="section-title">
      <h2>Herramientas</h2>
    </div>
    <div class="tools-grid">
      <a href="/comparador" class="tool-card">
        <span class="tool-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
            <rect x="2" y="4" width="14" height="28" rx="2" stroke="#E63946" stroke-width="2.5"/>
            <path d="M5 18l3 4 5-8" stroke="#E63946" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <rect x="20" y="4" width="14" height="28" rx="2" stroke="#E63946" stroke-width="2.5"/>
            <path d="M23 18l3 4 5-8" stroke="#E63946" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <h3>Comparador</h3>
        <p>Compara hasta 3 motos lado a lado con todas sus especificaciones.</p>
      </a>
      <a href="/calculadora-consumo" class="tool-card">
        <span class="tool-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
            <rect x="6" y="4" width="24" height="28" rx="3" stroke="#E63946" stroke-width="2.5"/>
            <rect x="9" y="8" width="18" height="7" rx="1" fill="#E63946" opacity="0.15"/>
            <line x1="12" y1="11.5" x2="24" y2="11.5" stroke="#E63946" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="12" cy="20" r="2" fill="#E63946"/>
            <circle cx="18" cy="20" r="2" fill="#E63946"/>
            <circle cx="24" cy="20" r="2" fill="#E63946"/>
            <circle cx="12" cy="27" r="2" fill="#E63946"/>
            <circle cx="18" cy="27" r="2" fill="#E63946"/>
            <circle cx="24" cy="27" r="2" fill="#E63946"/>
          </svg>
        </span>
        <h3>Calculadora de Consumo</h3>
        <p>Calcula cuánto gastarás en gasolina, SOAT y mantenimiento al año.</p>
      </a>
      <a href="/guias" class="tool-card">
        <span class="tool-icon">
          <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
            <path d="M4 6h14v24H4z" stroke="#E63946" stroke-width="2" stroke-linejoin="round"/>
            <path d="M18 6h14v24H18z" stroke="#E63946" stroke-width="2" stroke-linejoin="round"/>
            <path d="M18 6v24" stroke="#E63946" stroke-width="2"/>
            <line x1="8" y1="12" x2="14" y2="12" stroke="#E63946" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="8" y1="16" x2="14" y2="16" stroke="#E63946" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="22" y1="12" x2="28" y2="12" stroke="#E63946" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="22" y1="16" x2="28" y2="16" stroke="#E63946" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </span>
        <h3>Guías de Compra</h3>
        <p>Artículos para ayudarte a elegir la mejor moto según tu presupuesto.</p>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .ticker-bar {
    width: 100%;
    overflow: hidden;
    background: var(--color-secondary);
    padding: 12px 0;
    position: relative;
    box-shadow: inset 0 2px 6px rgba(0,0,0,0.15);
  }

  .ticker-bar::before,
  .ticker-bar::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 48px;
    z-index: 1;
    pointer-events: none;
  }

  .ticker-bar::before {
    left: 0;
    background: linear-gradient(to right, var(--color-secondary), transparent);
  }

  .ticker-bar::after {
    right: 0;
    background: linear-gradient(to left, var(--color-secondary), transparent);
  }

  .ticker-track {
    display: flex;
    align-items: center;
    width: fit-content;
    will-change: transform;
    backface-visibility: hidden;
  }

  .ticker-track.paused {
    animation-play-state: paused;
  }

  .ticker-item {
    color: var(--color-text-light);
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    padding: 0 4px;
    letter-spacing: 0.01em;
  }

  .ticker-sep {
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0 16px;
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none !important;
    }
  }
</style>

<script>
  (function() {
    var track = document.getElementById('tickerTrack')
    if (!track || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return

    var html = track.innerHTML
    var itemCount = track.children.length
    track.innerHTML = html + html
    var oneSet = track.scrollWidth / 2
    track.innerHTML = html + html + html
    var pos = 0
    var playing = true

    function tick() {
      if (!playing) { requestAnimationFrame(tick); return }
      pos -= 0.4
      if (pos <= -oneSet) {
        pos += oneSet
        for (var i = 0; i < itemCount; i++) {
          track.appendChild(track.children[0])
        }
      }
      track.style.transform = 'translateX(' + pos + 'px)'
      requestAnimationFrame(tick)
    }

    var bar = track.parentElement
    bar.addEventListener('mouseenter', function() { playing = false })
    bar.addEventListener('mouseleave', function() { playing = true })
    bar.addEventListener('touchstart', function() { playing = false })
    bar.addEventListener('touchend', function() { playing = true })

    requestAnimationFrame(tick)
  })()
</script>
