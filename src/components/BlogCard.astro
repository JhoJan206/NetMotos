---
export interface Props {
  post: {
    slug: string
    title: string
    excerpt: string
    category: string
    date: string
    author?: string
    cover_image?: string
  }
}

const { post } = Astro.props

const CATEGORY_COLORS: Record<string, string> = {
  Lanzamientos: '#FFE0E0',
  'Guías': '#FFF3D6',
  Normativa: '#D6E8FF',
  Noticias: '#D6FFE0',
  Deportes: '#E8D6FF',
  'Seguridad Vial': '#FFD6E8',
}
const bgColor = CATEGORY_COLORS[post.category] || '#F0F0F0'
---

<article class="blog-card">
  <a href={`/blog/${post.slug}`} class="blog-card-image" style={`background: ${bgColor}`}>
    {post.cover_image ? (
      <img src={post.cover_image} alt={post.title} class="blog-card-img" loading="lazy" />
    ) : (
      <div class="blog-card-placeholder">
        <span>{post.category[0]}</span>
      </div>
    )}
  </a>
  <div class="blog-card-body">
    <div class="blog-card-meta">
      <span class={`tag tag-${post.category.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')}`}>
        {post.category}
      </span>
      <span class="blog-date">{post.date}</span>
    </div>
    <h3 class="blog-card-title">
      <a href={`/blog/${post.slug}`}>{post.title}</a>
    </h3>
    <p class="blog-card-excerpt">{post.excerpt}</p>
    <div class="blog-card-footer">
      <span class="blog-author">{post.author}</span>
    </div>
  </div>
</article>
