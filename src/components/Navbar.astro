---
const { currentPath = '' } = Astro.props
---

<nav class="navbar">
  <div class="container navbar-inner">
    <a href="/" class="navbar-brand">
      <span class="brand-icon">M</span>
      <span class="brand-text">NetMotos</span>
    </a>
    <button class="nav-toggle" id="navToggle" aria-label="Menú">
      <span class="hamburger" />
    </button>
    <div class="nav-menu" id="navMenu">
      <a href="/fichas-tecnicas" class={currentPath.startsWith('/fichas-tecnicas') ? 'active' : ''}>Fichas Técnicas</a>
      <a href="/comparador" class={currentPath === '/comparador' ? 'active' : ''}>Comparador</a>
      <a href="/calculadora-consumo" class={currentPath === '/calculadora-consumo' ? 'active' : ''}>Calculadora</a>
      <a href="/blog" class={currentPath.startsWith('/blog') ? 'active' : ''}>Noticias</a>
      <a href="/guias" class={currentPath === '/guias' ? 'active' : ''}>Guías</a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('navToggle')
  const menu = document.getElementById('navMenu')
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('open')
      toggle.querySelector('.hamburger')?.classList.toggle('open')
    })
  }
</script>
